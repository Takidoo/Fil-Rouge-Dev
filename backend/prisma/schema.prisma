generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  name         String
  password     String
  createdAt    DateTime       @default(now())
  role         Role           @default(USER)
  videos       Video[]
  comments     Comment[]
  watchHistory WatchHistory[]
  favorites    Favorite[]
}

model Video {
  id            String         @id @default(uuid())
  title         String
  description   String
  searchText    String         @default("")
  path          String
  thumbnailPath String?
  hlsPath       String?
  uploadedAt    DateTime       @default(now())
  userId        String

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  genres       Genre[]
  comments     Comment[]
  watchHistory WatchHistory[]
  favorites    Favorite[]

  @@index([searchText])
}

model Genre {
  id     String  @id @default(uuid())
  name   String  @unique
  slug   String  @unique
  videos Video[]
}

model Comment {
  id        String        @id @default(uuid())
  content   String
  status    CommentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  userId    String
  videoId   String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model WatchHistory {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  progress  Int      @default(0)
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  addedAt   DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}
